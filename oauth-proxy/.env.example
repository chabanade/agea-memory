# Exemple de variables pour l'OAuth proxy (voir brief Phase 18).
# A ajouter au /opt/agea/.env en production, JAMAIS dans git.
OAUTH_ISSUER=https://srv987452.hstgr.cloud/mcp-oauth
OAUTH_JWT_SECRET=<openssl rand -hex 32>
OAUTH_ACCESS_TOKEN_TTL=3600
OAUTH_REFRESH_TOKEN_TTL=2592000
OAUTH_AUTH_CODE_TTL=600
OAUTH_ADMIN_APPROVAL_TOKEN=<openssl rand -hex 16>
MCP_INTERNAL_URL=http://mcp-remote:8888/mcp
OAUTH_DB_PATH=/data/oauth.db
OAUTH_AUDIT_LOG=/data/audit.log
